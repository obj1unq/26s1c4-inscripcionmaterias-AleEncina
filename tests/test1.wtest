import clases.materiaYUnaAprobada.*
import clases.estudiante.*
import clases.inscripcion.*
import clases.carreraYCurso.*

describe "Inscripcion a materias" {
    //carreras
    const programación = new Carrera(materiasObligatorias=[baseDeDatos, matematica1, elementosDeProgramacion, objetos1, objetos2, objetos3, programacionConcurrente])
    const medicina = new Carrera(materiasObligatorias=[biologia1, biologia2])
    //materias 
    const biologia1 = new Materia (cupo=10)
    const biologia2 = new Materia (cupo=10,requisitos=[biologia1])
    const baseDeDatos = new Materia (cupo=10)
    const matematica1= new Materia (cupo=10)
    const elementosDeProgramacion = new Materia (cupo=2)
    const objetos1 = new Materia (cupo=10,requisitos=[matematica1])
    const objetos2 = new Materia (cupo=3,requisitos=[objetos1, matematica1])
    const objetos3 = new Materia (cupo=10,requisitos=[objetos2, baseDeDatos])
    const programacionConcurrente = new Materia (cupo=2,requisitos=[objetos1, baseDeDatos])
    //estudiantes
    const roque = new Estudiante (cursoActual="Programacion", carrerasElegidas=[programación, medicina], materiasAprobadas=[ new MateriaAprobada(
    materia=elementosDeProgramacion, nota=8), matematica1, objetos1, baseDeDatos, biologia1])
    const luisa = new Estudiante (cursoActual="Programacion", carrerasElegidas=[programación], materiasAprobadas=[elementosDeProgramacion, matematica1, objetos1])
    const romina = new Estudiante (cursoActual="Programacion", carrerasElegidas=[programación], materiasAprobadas=[elementosDeProgramacion, matematica1, objetos1])
    const alicia = new Estudiante (cursoActual="Programacion", carrerasElegidas=[programación], materiasAprobadas=[elementosDeProgramacion, matematica1, objetos1])
    const ana = new Estudiante (cursoActual="Programacion", carrerasElegidas=[programación], materiasAprobadas=[elementosDeProgramacion])


    method initialize() {
        //objetos2.inscribir(luisa)
        //objetos2.inscribir(romina)
        //objetos2.inscribir(alicia)
        //objetos2.inscribir(roque)
    }  

    test "Roque se inscribe en objetos2 con los requisitos cumplidos y con cupo disponible" {
        assert.equals(true, roque.puedeInscribirseEn(objetos2))
    }

    test "Roque no se puede inscribir en objetos3 sin haber aprobado objetos2 ni en objetos1 al tenerlo aprobado" {
        assert.equals(false, roque.puedeInscribirseEn(objetos3))
        assert.equals(false, roque.puedeInscribirseEn(objetos1))
    }

    test "Roque se inscribe en objetos2 con los requisitos cumplidos pero sin cupo disponible" {
        self.inscribirEstudiantesEnObjetos2()
        assert.that(objetos2.estudiantesInscriptos().contains(romina))
        assert.that(objetos2.estudiantesEnEspera().contains(roque))
    }

    test "Romina se da de baja de objetos2 y pasa al primer lugar disponible en inscriptos" {
        self.inscribirEstudiantesEnObjetos2()
        objetos2.darDeBaja(romina)
        assert.that(objetos2.estudiantesInscriptos().contains(roque))
        assert.that(!objetos2.estudiantesEnEspera().contains(roque))
        assert.that(!objetos2.estudiantesInscriptos().contains(romina))
        assert.that(!objetos2.estudiantesEnEspera().contains(romina))
}

method inscribirEstudiantesEnObjetos2() {
        luisa.inscribir(objetos2)
        romina.inscribir(objetos2)
        alicia.inscribir(objetos2)
        roque.inscribir(objetos2)
    }

}
